#!/bin/sh
# DeepSeek V4-Pro via a nested, read-only, isolated Claude Code instance.
# Raw output is for the dispatching conductor to adjudicate — never shown to the human verbatim.
set -eu

# Fail loud, before any network, if the key can't be resolved: neither exported nor readable via op.
if [ -z "${DEEPSEEK_API_KEY:-}" ] && ! command -v op >/dev/null 2>&1; then
   printf '%s\n' 'ds-review: DEEPSEEK_API_KEY unset and no `op` CLI to read it (see INSTALL.md)' >&2
   exit 1
fi

if [ "$#" -gt 0 ]; then
   prompt="$*"
else
   prompt="$(cat)"        # allow piping a review packet on stdin
fi

# Resolve the key into ANTHROPIC_API_KEY by shell assignment + export — never on a command line. The
# child must see it in its environment (unavoidable), but it must not transit any argv: `env VAR=$key
# cmd` would expose the key in env's argv (ps/proc-readable) for the exec's lifetime. `set -e` aborts
# here if `op read` errors; the guard below turns an empty-but-zero read into a loud local failure
# instead of a remote 401. (`exec VAR=… cmd` without env is a distinct, worse bug — see VERIFICATION.)
if [ -n "${DEEPSEEK_API_KEY:-}" ]; then
   ANTHROPIC_API_KEY="$DEEPSEEK_API_KEY"
else
   ANTHROPIC_API_KEY="$(op read 'op://Elliott - Work-visible/DeepSeek/API key')"
fi
[ -n "$ANTHROPIC_API_KEY" ] || {
   printf '%s\n' 'ds-review: DeepSeek key resolved empty (op read failed or was cancelled) — aborting before network' >&2
   exit 1
}
export ANTHROPIC_API_KEY

# Nested Claude Code against DeepSeek's Anthropic-compatible endpoint:
#   - prompt on STDIN, not argv: no ARG_MAX ceiling, no packet in the process table, one path whether
#     the packet arrived on our argv or our stdin. `claude -p` with no positional prompt reads stdin.
#   - model PINNED to native ids: DeepSeek maps claude-opus*→v4-pro but claude-sonnet/haiku* and any
#     unknown name→v4-flash, so an unpinned default reaches v4-pro only incidentally. Name it.
#   - read-only posture is EXPLICIT: allow Read/Grep/Glob + the two kagi tools; deny the mutating/
#     egress/escalation tools by name rather than relying on headless prompt auto-deny. Allow-listing
#     the read tools sanctions the tools, not paths — file access stays scoped to the cwd subtree, so
#     the caller dispatches from the artifacts' root (an out-of-tree Read still prompts, then denies).
#   - env hygiene: drop CLAUDECODE and every inherited var that could redirect the child's auth/model/
#     endpoint (a caller's ANTHROPIC_AUTH_TOKEN would else be sent to DeepSeek; CLAUDE_CODE_USE_BEDROCK/
#     VERTEX would divert it off-endpoint). Proxy vars are left intact so the child can still egress.
#   - CLAUDE_CONFIG_DIR from FOREIGN_CLAUDE_CONFIG_DIR (dedicated override), NOT the caller's own — the
#     latter would load the user's real skills/MCP/settings into the foreign lineage, defeating isolation.
printf '%s' "$prompt" | env \
   -u CLAUDECODE \
   -u ANTHROPIC_AUTH_TOKEN \
   -u ANTHROPIC_SMALL_FAST_MODEL \
   -u ANTHROPIC_DEFAULT_HAIKU_MODEL -u ANTHROPIC_DEFAULT_SONNET_MODEL -u ANTHROPIC_DEFAULT_OPUS_MODEL \
   -u CLAUDE_CODE_USE_BEDROCK -u CLAUDE_CODE_USE_VERTEX -u CLAUDE_CODE_SUBAGENT_MODEL \
   ANTHROPIC_BASE_URL="https://api.deepseek.com/anthropic" \
   ANTHROPIC_MODEL="deepseek-v4-pro" \
   ANTHROPIC_SMALL_FAST_MODEL="deepseek-v4-flash" \
   CLAUDE_CONFIG_DIR="${FOREIGN_CLAUDE_CONFIG_DIR:-$HOME/.config/foreign-claude}" \
   claude -p --output-format json \
      --disallowedTools "Edit,Write,Bash,NotebookEdit,WebFetch,WebSearch,Task" \
      --allowedTools "Read,Grep,Glob,mcp__kagi-ken__kagi_search_fetch,mcp__kagi-ken__kagi_summarizer" \
      --mcp-config "$HOME/.claude/bin/foreign-mcp.json" --strict-mcp-config
