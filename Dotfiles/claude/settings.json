{
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "MISE_AUTO_INSTALL": "false"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:agents.md)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:claude.ai)",
      "WebFetch(domain:www.claude.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:docs.cursor.com)",
      "WebFetch(domain:cursor.com)",
      "WebFetch(domain:docs.codeium.com)",
      "WebFetch(domain:code.visualstudio.com)",
      "WebFetch(domain:github.blog)",
      "WebFetch(domain:www.windmill.dev)",
      "WebFetch(domain:neon.tech)",
      "WebFetch(domain:neon.com)",
      "Read(//c/Users/ec/.claude/skills/prompt-review/**)",
      "Read(//c/Users/ec/System/Dotfiles/claude/skills/prompt-review/**)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/git-deny.mjs\"",
            "if": "Bash(*git*)"
          }
        ]
      },
      {
        "matcher": "PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "$j=[Console]::In.ReadToEnd()|ConvertFrom-Json; $cmd=$j.tool_input.command; $blocked=@('\\bgit\\s+push\\b','\\bgit\\s+rebase\\b','\\bgit\\s+merge\\b','\\bgit\\s+reset\\s+--hard\\b','\\bgit\\s+clean\\s+-[a-zA-Z]*f','\\bgit\\s+branch\\s+(-D|-d|--delete)\\b','\\bgit\\s+stash\\s+(drop|clear)\\b','\\bgit\\s+tag\\s+(-d|--delete)\\b','\\bgit\\s+filter-branch\\b','\\bgit\\s+filter-repo\\b','\\bgit\\s+update-ref\\b'); foreach($p in $blocked){ if($cmd -match $p){ [Console]::Error.WriteLine('Blocked: mutative git operation reserved for the user.'); exit 2 } }; if($cmd -match '(?i)\\bgit\\s+commit\\b'){ $root=(git rev-parse --show-toplevel 2>$null); $branch=(git branch --show-current 2>$null); if((Test-Path \"$root/.claude-commit\") -or ($branch -match '^ai/')){exit 0}; [Console]::Error.WriteLine(\"Blocked: git commit on '$branch' (requires ai/* branch or .claude-commit sentinel).\"); exit 2 }",
            "shell": "powershell"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "git",
        "url": "https://github.com/anthropics/claude-plugins-official.git"
      }
    },
    "claude-code-lsps": {
      "source": {
        "source": "github",
        "repo": "boostvolt/claude-code-lsps"
      }
    }
  },
  "promptSuggestionEnabled": false,
  "autoUpdatesChannel": "stable",
  "minimumVersion": "2.1.138",
  "theme": "auto",
  "editorMode": "vim",
  "verbose": true,
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
