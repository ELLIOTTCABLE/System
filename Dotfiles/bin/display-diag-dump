#!/usr/bin/env sh
# display-diag-dump — dump display state from every available macOS source.
#
# Modes:
#   --full    (default) dump everything verbatim
#   --stable  apply per-tool noise filters; suitable for diffing two
#             baselines across reconnects/re-topology events. The filter
#             set is tuned empirically — when noise still bleeds through
#             to a real diff, add to the relevant `filter_<tool>` below.
#
# Combined capture for diffing baselines:
#
#     display-diag-dump --stable 2>&1 \
#        > ~/Library/Logs/display-diag/baselines/display-diag-$(date -u +'%Y-%m-%d_%H.%M.%S').log
#
# Watch live while capturing (slow on first run; many `Failed.` are normal):
#
#     display-diag-dump --stable 2>&1 \
#        | tee ~/Library/Logs/display-diag/baselines/display-diag-$(date -u +'%Y-%m-%d_%H.%M.%S').log
#
# Sources:
# - `system_profiler` (basically the same as the GUI; uniquely has GPU info
#   beyond display info)
# - `log show` predicate against AppleDCPDPTXController (Apple Silicon DCP
#   driver chatter — DSC negotiation, link bandwidth, pixel clock; returns
#   little/nothing on Intel, harmless)
# - `displayplacer` (concise current arrangement; simple to install)
# - `betterdisplaycli` (Apple Silicon connection-mode access; per-display)
# - `AllRez` (joevt) — reimplements AGDCDiagnose (~1400 LoC C++) AND does
#   its own per-display IORegistry traversal. When installed, it subsumes
#   both `AGDCDiagnose` and the `ioreg -c IODisplayConnect`/`-c AppleDisplay`
#   calls below, so we skip those to avoid duplication.
# - Fallback when AllRez is missing:
#   - `ioreg -r -c IODisplayConnect` and `-r -c AppleDisplay`
#   - `AGDCDiagnose -a` (Intel-only) from `AppleGraphicsControl.kext`
#
# Exits non-zero (counting how many) when any tool was missing.

set -u

mode=full
case "${1:-}" in
   --stable)  mode=stable; shift ;;
   --full)    mode=full;   shift ;;
   --help|-h)
      cat <<EOF
Usage: $(basename "$0") [--full|--stable]
   --full    (default) dump everything verbatim
   --stable  apply per-tool noise filters for diffing baselines
EOF
      exit ;;
   '')        ;;
   *)         echo "unknown flag: $1" >&2; exit 2 ;;
esac

x() { printf \\n; (set -x; exec "$@"); }
xfilter() {
   if [ "$mode" = stable ]; then
      printf \\n; (set -x; exec "$@") | "filter_$(basename "$1")"
   else x "$@"; fi; }

# Per-tool noise filters — named `filter_<command>` and dispatched by xfilter.

# shellcheck disable=SC2016,SC2317,SC2329
{
   filter_system_profiler() {
      sed -E '
         # Per-call timestamp + PID + thread ID prefix on stderr-sniff lines
         s/^[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9:]+\.[0-9]+ system_profiler\[[0-9]+:[0-9]+\] /system_profiler[T] /
         # Auto-adjusted brightness
         /^[[:space:]]*Brightness:/d
      '
   }

   filter_ioreg() {
      sed -E '
         # busy/retain runtime counters baked into class-header lines
         s/busy [0-9]+ \([0-9]+ ms\)/busy N (T ms)/g
         s/, retain [0-9]+>/, retain N>/g
         # power-state values inside IOPowerManagement dicts
         s/"(DevicePowerState|CurrentPowerState)"=[0-9]+/"\1"=N/g
         # Standalone single-line power-state declarations (intermittent)
         /^[[:space:]]*DevicePowerState = [0-9]+;$/d
      '
   }

   filter_displayplacer() {
      # Contextual screen ID changes, but that's important debugging
      # information, as they are used in many apps.
      cat
   }

   # AllRez bundles AGDCDiagnose output verbatim, so its filter has to
   # cover both: AllRez-native noise (timing handles, cursor position,
   # IOService allocs) AND AGDC noise (kernel trace event log).
   filter_AllRez() {
      sed -E '
         # busy/retain counters
         s/busy [0-9]+ \([0-9]+ ms\)/busy SNIP (SNIP ms)/g
         s/, retain [0-9]+>/, retain SNIP>/g

         # Power-management state (noisy; intermittent display sleep)
         /^[[:space:]]+Brightness = /d
         /CurrentPowerState/d

         # Per-process IOService numeric handles & runtime pointers
         s/IOService = 0x[0-9a-f]+;/IOService = 0xSNIP;/g
         s/IOFramebuffer 0x[0-9a-f]+ =/IOFramebuffer 0xSNIP =/g
         s/IODisplay 0x[0-9a-f]+ =/IODisplay 0xSNIP =/g
         s/<CGColorSpace 0x[0-9a-f]+>/<CGColorSpace 0xSNIP>/g
         s/CFBundle 0x[0-9a-f]+ /CFBundle 0xSNIP /g
         s/modeAlias = [0-9]+/modeAlias = SNIP/g
         s/id:0x8000[0-9a-f]{4}/id:0x8000SNIP/g

         # Cursor position (changes constantly during use)
         s/(kIOFBCursorMemory = \{ size:)[0-9]+( version:)[0-9]+( location:)-?[0-9]+x-?[0-9]+/\1SNIP\2SNIP\3SNIPxSNIP/g

         # AGDC GTrace per-event timestamps & counters
         s/Last Event  : [0-9]+ \(0x[0-9a-f]+\)/Last Event  : SNIP (0xSNIP)/g
         s/Stamp Start : 0x[0-9a-f]+/Stamp Start : 0xSNIP/g
         s/Stamp Delta : [0-9]+ ns/Stamp Delta : SNIP ns/g
         s/\(took [0-9]+\.[0-9]+ sec\)/(took SNIP sec)/g

         # AllRez "unexpected data" hex captures (binary state per-run)
         s/\(unexpected data: [0-9a-f]+\)/(unexpected data: HEX SNIP)/g
         s/\(unexpected data at offset [0-9]+: [0-9a-f]+\)/(unexpected data at offset SNIP: HEX SNIP)/g

         # AllRez DPCD-read-error attempt offset
         s/\([0-9a-f]+h: dpErrReadDpcd /(SNIPh: dpErrReadDpcd /g

         # AppleDisplay-Portrait suffix: applied non-deterministically
         # by the OS to rotated displays. Real rotation is captured via
         # `displayplacer` Rotation: lines.
         s/AppleDisplay-Portrait/AppleDisplay/g

         # AGDC kernel trace event log entries (~thousands of lines per
         # run of pure non-deterministic instrumentation)
         /timestamp:[[:space:]]+[0-9]+=[0-9]{4}-[0-9]{2}-[0-9]{2}/d
         /\{ timestamp:[0-9]+=[0-9]{4}-[0-9]{2}-[0-9]{2}/d
         /^[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9:]+\.[0-9]+-[0-9]+:[[:space:]]*kAGDCPlugin/d

         # Catch-all for any remaining long hex pointer/handle (10+ hex
         # digits is essentially always an address or runtime ID)
         s/0x[0-9a-f]{10,}/0xAUTOSNIP/g
      '
   }

   # When AllRez is missing and we fall back to invoking AGDCDiagnose
   # directly, the AGDC-specific subset of the AllRez filter applies.
   filter_AGDCDiagnose() {
      sed -E '
         /timestamp:[[:space:]]+[0-9]+=[0-9]{4}-[0-9]{2}-[0-9]{2}/d
         /\{ timestamp:[0-9]+=[0-9]{4}-[0-9]{2}-[0-9]{2}/d
         /^[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9:]+\.[0-9]+-[0-9]+:[[:space:]]*kAGDCPlugin/d
         s/Last Event  : [0-9]+ \(0x[0-9a-f]+\)/Last Event  : SNIP (0xSNIP)/g
         s/Stamp Start : 0x[0-9a-f]+/Stamp Start : 0xSNIP/g
         s/Stamp Delta : [0-9]+ ns/Stamp Delta : SNIP ns/g
         s/\(took [0-9]+\.[0-9]+ sec\)/(took SNIP sec)/g
         s/0x[0-9a-f]{10,}/0xAUTOSNIP/g
      '
   }
}

missing_count=0
missing() { missing_count=$((missing_count + 1)); echo "missing: $*" >&2; }

x date # unstable, but distinguishes runs
x uname -a
x sw_vers
xfilter system_profiler SPDisplaysDataType
[ "$mode" = full ] && x log show --last 1h --info \
   --predicate "processImagePath CONTAINS 'kernel' AND senderImagePath CONTAINS 'DCP'"

if command -v displayplacer >/dev/null; then
   xfilter displayplacer list
else
   # shellcheck disable=SC2016
   missing 'displayplacer (`brew install displayplacer`)'
fi

# AllRez reimplements AGDCDiagnose and re-reads IOReg display properties
# itself, so when installed it subsumes both — skip the redundant calls.
if command -v AllRez >/dev/null; then
   xfilter AllRez
else
   # shellcheck disable=SC2016
   missing 'AllRez (`mise install github:joevt/AllRez` or `ubi --project joevt/AllRez --in ~/.bin`)'

   xfilter ioreg -l -w 0 -r -c IODisplayConnect
   xfilter ioreg -l -w 0 -r -c AppleDisplay

   agc_dir="$(dirname "$(locate -l1 AGDCDiagnose 2>/dev/null)")"
   if [ -x "$agc_dir" ]; then
      export PATH="$agc_dir:$PATH"
      xfilter AGDCDiagnose -a
   else
      missing 'AGDCDiagnose (Intel Macs only)'
   fi
fi

if command -v betterdisplaycli >/dev/null; then
   if [ "$mode" = stable ]; then
      x "$(dirname "$0")/display-diag-betterdisplaycli-dump" --stable
   else
      x "$(dirname "$0")/display-diag-betterdisplaycli-dump"
   fi
else
   # shellcheck disable=SC2016
   missing 'betterdisplaycli (`brew install --cask betterdisplay`, run app, authorize w/ macOS)'
fi

exit "$missing_count"
